# ─────────────────────────────────────────────────────────
#  Lineside — Environment Variables (PRODUCTION)
#  Fill in your real values below. Never commit this file.
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Public-facing base URL — no trailing slash.
# Used in password-reset emails and OAuth redirect URIs.
BASE_URL=https://YOUR_DOMAIN_HERE

# ── Database (Supabase) ───────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key (server-side only — never expose to the client)
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Anon/publishable key
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Object Storage (Cloudflare R2) ────────────────────────
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=spotter-storage
# Public URL for the R2 bucket — no trailing slash
R2_PUBLIC_URL=https://spotter-images.harryfaulkner.com

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY

# ── Error Tracking (Sentry) ───────────────────────────────
SENTRY_DSN=YOUR_SENTRY_DSN

# ── Content Moderation (Sightengine) — optional ──────────
# Leave blank to disable automated image moderation on upload.
SIGHTENGINE_USER=YOUR_SIGHTENGINE_USER
SIGHTENGINE_SECRET=YOUR_SIGHTENGINE_SECRET
