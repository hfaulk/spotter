# ─────────────────────────────────────────────────────────
#  Lineside — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Public-facing base URL (no trailing slash)
BASE_URL=https://yourdomain.com

# ── Database (Supabase) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service role key (server-side only — never expose to the client)
SUPABASE_SECRET_KEY=your-supabase-service-role-key
# Anon/publishable key (used for client-safe operations)
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Object Storage (Cloudflare R2) ────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# Public URL for the R2 bucket (no trailing slash)
R2_PUBLIC_URL=https://your-r2-public-domain.com

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Error Tracking (Sentry) ───────────────────────────────
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── Content Moderation (Sightengine) — optional ──────────
# Leave blank to disable automated image moderation on upload.
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=
