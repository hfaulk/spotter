<%- include('../partials/header') %>

<div class="show-page">

    <div class="spot-image-full" id="unit-hero">
      <div class="spot-image-bg" id="unit-hero-bg" style="display:none"></div>
      <div class="unit-hero-placeholder" id="unit-hero-placeholder"></div>
      <img id="unit-hero-img" src="" alt="" style="display:none;" />
      <button class="spot-back-btn js-back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back
      </button>
    </div>

    <div class="show-right">
        <div class="spot-title-block">
          <h1 class="unit-hero-number"><%= unit.unit_number %></h1>
          <div class="unit-hero-meta">
            <% if (unit.unit_class) { %><span class="unit-badge"><%= unit.unit_class %></span><% } %>
            <% if (unit.unit_operator) { %><span class="unit-badge"><%= unit.unit_operator %></span><% } %>
          </div>
          <p class="unit-spotted-count"><%= spots.length %> time<%= spots.length !== 1 ? 's' : '' %> spotted</p>
        </div>

        <div class="unit-content">

            <div class="spot-card unit-wiki-card" id="wiki-card" data-unit-class="<%= unit.unit_class || '' %>" style="display:none;">
            <h2>About this class</h2>
            <div id="wiki-content">
              <p class="section-hint">Loading...</p>
            </div>
          </div>

          <div class="unit-spots-card">
            <h2 class="unit-spots-heading">Your spots</h2>
            <% if (spots.length === 0) { %>
              <div class="empty-state">
                <p>No spots logged for this unit yet.</p>
              </div>
            <% } else { %>
              <div class="spots-list">
                <% spots.forEach(spot => { %>
                  <a href="/spots/<%= spot.spot_id %>" class="spot-item">
                      <div class="spot-item-photo">
                        <% if (spot.image_thumb_path || spot.image_path) { %>
                          <img src="<%= process.env.R2_PUBLIC_URL %>/<%= spot.image_thumb_path || spot.image_path %>" loading="lazy" alt="Spot photo" />
                        <% } else { %>
                          <div class="spot-item-no-photo"><span>No photo</span></div>
                        <% } %>
                      </div>
                    <div class="spot-item-info">
                      <p class="spot-item-title"><%= spot.spot_title %></p>
                      <p class="spot-item-time"><%= new Date(spot.spot_timestamp).toLocaleString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </div>

        </div>
      </div>

  <%- include('../partials/bottomnav', { activePage }) %>
</div>

<script src="/js/main.js"></script>
<script src="/js/unit-show.js"></script>
</body>
</html>

</body>
</html>
