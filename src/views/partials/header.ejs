<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=18" />

  <!-- ===== PWA (12) ===== -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#191970" />
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="Lineside" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />

  <link rel="icon" type="image/svg+xml" href="/icons/icon.svg">

  <script src="/js/toast.js?v=1"></script>
  <script src="/js/main.js?v=1"></script>

  <% if (locals.spot) { %>
    <title><%= spot.spot_title %> | Lineside</title>
    <meta property="og:title" content="<%= spot.spot_title %>">
    <meta property="og:description" content="Spotted with Lineside. <%= spot.spot_description ? spot.spot_description : 'Tap to see the location, units, and camera details.' %>">
    <meta property="og:type" content="website">

    <% const ogImage = spot.image_thumb_path ? `${process.env.R2_PUBLIC_URL}/${spot.image_thumb_path}` : (locals.imageUrl ? imageUrl : null); %>

    <% if (ogImage) { %>
      <meta property="og:image" content="<%= ogImage %>">
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:title" content="<%= spot.spot_title %>">
      <meta name="twitter:description" content="Spotted with Lineside">
      <meta name="twitter:image" content="<%= ogImage %>">
    <% } %>

  <% } else { %>
    <title>Lineside</title>
    <meta property="og:title" content="Lineside">
    <meta property="og:description" content="Discover, log, and share your best spotting locations.">
    <meta property="og:type" content="website">
  <% } %>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {})
      })
    }
  </script>
</head>
<body>
<%- include('sidenav') %>
