<%
  const initials = ((locals.currentUser?.first_name?.[0] || '') + (locals.currentUser?.last_name?.[0] || '')).toUpperCase()
  const isAdmin = locals.authUser?.id === process.env.ADMIN_USER_ID
%>

<nav class="bottomnav">
  <a href="/map" class="nav-item <%= activePage === 'map' ? 'active' : '' %>" aria-label="Map">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
      <line x1="8" y1="2" x2="8" y2="18"/>
      <line x1="16" y1="6" x2="16" y2="22"/>
    </svg>
  </a>

  <a href="/spots/new" class="nav-item nav-item-new js-open-spot-sheet <%= activePage === 'new' ? 'active' : '' %>" aria-label="Log a spot">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
  </a>

  <a href="/profile#spots" class="nav-item <%= activePage === 'profile' ? 'active' : '' %>" aria-label="Profile">
    <div class="nav-avatar <%= activePage === 'profile' ? 'nav-avatar-active' : '' %>">
      <span><%= initials %></span>
    </div>
  </a>

  <% if (isAdmin) { %>
    <a href="/admin" class="nav-item <%= activePage === 'admin' ? 'active' : '' %>" aria-label="Admin">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </a>
  <% } %>
</nav>
