<% if (locals.authUser) { %>
<%
  const initials = ((locals.currentUser?.first_name?.[0] || '') + (locals.currentUser?.last_name?.[0] || '')).toUpperCase()
  const isAdmin = locals.authUser?.id === process.env.ADMIN_USER_ID
%>
<aside class="sidenav">
  <a href="/profile#spots" class="sidenav-brand">
    <svg width="8" height="8" viewBox="0 0 8 8">
      <circle cx="4" cy="4" r="4" fill="midnightblue"/>
    </svg>
    Lineside
  </a>

  <nav class="sidenav-nav">
    <a href="/spots/new" class="sidenav-item sidenav-item-new js-open-spot-sheet" data-path="/spots/new">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Log a spot
    </a>
    <a href="/map" class="sidenav-item" data-path="/map">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
        <line x1="8" y1="2" x2="8" y2="18"/>
        <line x1="16" y1="6" x2="16" y2="22"/>
      </svg>
      Map
    </a>
    <a href="/profile" class="sidenav-item" data-path="/profile">
      <div class="sidenav-avatar"><%= initials %></div>
      Profile
    </a>
  </nav>

  <div class="sidenav-footer">
    <% if (isAdmin) { %>
      <a href="/admin" class="sidenav-item" data-path="/admin">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Admin
      </a>
    <% } %>
    <a href="/settings" class="sidenav-item" data-path="/settings">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l-.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
      Settings
    </a>
    <a href="/signout" class="sidenav-item sidenav-item-signout">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Sign out
    </a>
  </div>
</aside>

<script>
  const _path = window.location.pathname
  document.querySelectorAll('.sidenav-item[data-path]').forEach(el => {
    const p = el.getAttribute('data-path')
    if (_path === p || (_path.startsWith(p) && p !== '/map')) {
      el.classList.add('active')
    }
  })
</script>

<% if (!locals.spotSheetDisabled) { %>
  <%- include('spot-form-sheet') %>
<% } %>
<% } %>
