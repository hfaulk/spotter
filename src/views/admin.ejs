<%- include('partials/header') %>
<script src="/js/toast.js"></script>

<div class="app-page">
  <%- include('partials/topbar', { showBack: true }) %>

  <!-- Force main content wrapper to expand -->
  <main class="app-content" style="max-width: 1200px !important; width: 100%; margin: 0 auto; padding: 1rem;">
    <!-- Force settings page container to 100% of the 1200px main -->
    <div class="settings-page" style="max-width: 100% !important; width: 100%;">

      <!--<h1 style="font-size: 1.1rem; font-weight: 700; color: #0f172a; margin: 0 0 1.25rem 0;">Admin</h1>-->

      <!-- ===== STATS ===== -->
      <div class="settings-card" style="margin-bottom: 1rem; max-width: 100% !important;">
        <h2 class="settings-heading">Overview</h2>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1rem;">
          <div class="stat">
            <span class="stat-value"><%= stats.totalUsers %></span>
            <span class="stat-label">Users</span>
          </div>
          <div class="stat">
            <span class="stat-value"><%= stats.totalSpots %></span>
            <span class="stat-label">Spots</span>
          </div>
          <div class="stat">
            <span class="stat-value"><%= stats.spotsThisWeek %></span>
            <span class="stat-label">This week</span>
          </div>
          <div class="stat">
            <span class="stat-value" style="<%= stats.pendingReports > 0 ? 'color: darkred;' : '' %>">
              <%= stats.pendingReports %>
            </span>
            <span class="stat-label">Reports</span>
          </div>
        </div>
      </div>

      <!-- ===== REPORTED SPOTS ===== -->
      <div class="settings-card" style="margin-bottom: 1rem; max-width: 100% !important;">
        <h2 class="settings-heading">Reported Spots</h2>

        <% if (reportedSpots.length === 0) { %>
          <p class="section-hint" style="margin-top: 0.75rem;">No reported spots — all clear.</p>
        <% } else { %>
          <div style="margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.75rem;">

            <% reportedSpots.forEach(spot => { %>
              <div class="admin-card admin-report-row" id="report-row-<%= spot.spot_id %>" style="border: 1px solid #f0f2f8; border-radius: 8px; padding: 1rem; background: <%= spot.active ? '#ffffff' : '#fef2f2' %>;">

                <!-- Card Header (User Meta & Main Action) -->
                <div class="admin-card-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f0f0f0; padding-bottom: 12px; margin-bottom: 12px;">
                    <div class="spot-meta" style="display: flex; align-items: center; gap: 8px; font-size: 0.9rem;">
                        <span class="text-muted">by</span>
                        <strong>@<%= spot.username %></strong>
                        <span class="dot-divider" style="color: #d1d5db;">&bull;</span>
                        <span class="text-muted"><%= new Date(spot.spot_timestamp).toLocaleDateString('en-GB') %></span>
                        <span class="badge badge-visible" data-status style="padding: 2px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; color: <%= spot.active ? '#374151' : 'darkred' %>; background-color: <%= spot.active ? '#f3f4f6' : '#fbcfe8' %>;">
                          <%= spot.active ? 'Visible' : 'Hidden' %>
                        </span>
                    </div>

                    <button
                      class="btn-outline-danger js-toggle-spot"
                      data-spot-id="<%= spot.spot_id %>"
                      data-active="<%= spot.active %>"
                      style="border: 1px solid #ef4444; color: #ef4444; background: transparent; padding: 6px 14px; border-radius: 6px; font-weight: 500; cursor: pointer;"
                    >
                      <%= spot.active ? 'Hide spot' : 'Restore spot' %>
                    </button>
                </div>

                <!-- Spot Title Context -->
                <div style="margin-bottom: 12px; font-weight: 600; color: #0f172a; font-size: 0.95rem;">
                   <%= spot.spot_title %>
                </div>

                <!-- Individual reports list -->
                <div class="reports-container" id="reports-list-<%= spot.spot_id %>" style="display: flex; flex-direction: column; gap: 10px;">
                    <% spot.reports.forEach(function(report) { %>
                        <div class="report-item" id="report-<%= report.report_id %>" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 6px; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center;">
                            <div class="report-info">
                                <p class="report-reason" style="margin: 0 0 4px 0; font-style: italic; color: #111827; font-size: 0.95rem;">"<%= report.reason %>"</p>
                                <span class="report-date text-muted" style="color: #6b7280; font-size: 0.85rem;">
                                  <%= report.created_at ? new Date(report.created_at).toLocaleDateString('en-GB') : '—' %>
                                </span>
                            </div>
                            <button
                              class="btn-text js-dismiss-report"
                              data-report-id="<%= report.report_id %>"
                              data-spot-id="<%= spot.spot_id %>"
                              style="background: none; border: none; color: #6b7280; font-weight: 500; cursor: pointer;"
                            >
                              Dismiss
                            </button>
                        </div>
                    <% }); %>
                </div>
              </div>
            <% }) %>

          </div>
        <% } %>
      </div>

      <!-- ===== RECENT REGISTRATIONS ===== -->
      <div class="settings-card" style="max-width: 100% !important;">
        <h2 class="settings-heading">Recent Registrations</h2>

        <% if (recentUsers.length === 0) { %>
          <p class="section-hint" style="margin-top: 0.75rem;">No users yet.</p>
        <% } else { %>
          <div style="margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0;">
            <% recentUsers.forEach((user, i) => { %>
              <div style="
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0.6rem 0;
                border-bottom: <%= i < recentUsers.length - 1 ? '1px solid #f0f2f8' : 'none' %>;
              ">
                <div>
                  <p style="margin: 0; font-size: 0.875rem; font-weight: 500; color: #0f172a;">
                    @<%= user.username || '(no username)' %>
                  </p>
                  <p class="section-hint" style="margin: 0;">
                    <%= user.first_name || '' %> <%= user.last_name || '' %>
                  </p>
                </div>
                <p class="section-hint" style="margin: 0; text-align: right;">
                  <%= user.created_at ? new Date(user.created_at).toLocaleDateString('en-GB') : '—' %>
                </p>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>
  </main>

  <%- include('partials/bottomnav', { activePage: 'admin' }) %>
</div>

<script>
  // ===== TOGGLE SPOT VISIBILITY =====
  document.querySelectorAll('.js-toggle-spot').forEach(btn => {
    btn.addEventListener('click', async () => {
      const spotId = btn.dataset.spotId;
      const isActive = btn.dataset.active === 'true';

      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        const res = await fetch(`/admin/spots/${spotId}/toggle-active`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });

        if (!res.ok) throw new Error();
        const data = await res.json();

        btn.dataset.active = String(data.active);
        btn.textContent = data.active ? 'Hide spot' : 'Restore spot';

        const row = document.getElementById(`report-row-${spotId}`);
        if (row) {
          row.style.background = data.active ? '#ffffff' : '#fef2f2';

          const statusSpan = row.querySelector('[data-status]');
          if (statusSpan) {
            statusSpan.textContent = data.active ? 'Visible' : 'Hidden';
            statusSpan.style.color = data.active ? '#374151' : 'darkred';
            statusSpan.style.backgroundColor = data.active ? '#f3f4f6' : '#fbcfe8';
          }
        }

        toast.success(data.active ? 'Spot restored' : 'Spot hidden');
      } catch {
        toast.error('Failed to update spot — please try again.');
        btn.textContent = isActive ? 'Hide spot' : 'Restore spot';
      } finally {
        btn.disabled = false;
      }
    });
  });

  // ===== DISMISS INDIVIDUAL REPORT =====
  document.querySelectorAll('.js-dismiss-report').forEach(btn => {
    btn.addEventListener('click', async () => {
      const reportId = btn.dataset.reportId;
      const spotId = btn.dataset.spotId;

      btn.disabled = true;
      btn.textContent = '...';

      try {
        const res = await fetch(`/admin/reports/${reportId}/dismiss`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });

        if (!res.ok) throw new Error();

        const reportEl = document.getElementById(`report-${reportId}`);
        reportEl?.remove();

        const reportsList = document.getElementById(`reports-list-${spotId}`);
        if (reportsList && reportsList.children.length === 0) {
          document.getElementById(`report-row-${spotId}`)?.remove();
        }

        toast.success('Report dismissed');
      } catch {
        toast.error('Failed to dismiss report — please try again.');
        btn.disabled = false;
        btn.textContent = 'Dismiss';
      }
    });
  });
</script>

</body>
</html>
