<%- include('partials/header') %>
<script src="/js/toast.js"></script>

<div class="app-page">
  <%- include('partials/topbar', { showBack: true }) %>

  <main class="app-content" style="max-width: 1200px !important; width: 100%; margin: 0 auto; padding: 0;">
    <div class="settings-page" style="max-width: 100% !important; width: 100%; padding: 1rem; padding-top: 2rem;">

      <h1 style="font-size: 1.1rem; font-weight: 700; color: #0f172a; margin: 0 0 1.25rem 0;">Admin</h1>

      <div class="settings-card" style="margin-bottom: 1rem; max-width: 100% !important;">
        <h2 class="settings-heading">System Health</h2>
        <div style="display: flex; gap: 1rem; margin-top: 0.75rem;">
          <div style="padding: 0.5rem 1rem; border-radius: 6px; background: <%= healthStatus.supabase ? '#f0fdf4' : '#fef2f2' %>;">
            <span style="font-size: 0.85rem; font-weight: 500; color: <%= healthStatus.supabase ? '#166534' : '#991b1b' %>;">
              Database: <%= healthStatus.supabase ? 'Online' : 'Offline' %>
            </span>
          </div>
        </div>
      </div>

      <div class="settings-card" style="margin-bottom: 1rem; max-width: 100% !important;">
        <h2 class="settings-heading">Overview</h2>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1rem;">
          <div class="stat">
            <span class="stat-value"><%= stats.totalUsers %></span>
            <span class="stat-label">Users</span>
          </div>
          <div class="stat">
            <span class="stat-value"><%= stats.totalSpots %></span>
            <span class="stat-label">Spots</span>
          </div>
          <div class="stat">
            <span class="stat-value"><%= stats.spotsThisWeek %></span>
            <span class="stat-label">This week</span>
          </div>
          <div class="stat">
            <span class="stat-value" style="<%= stats.pendingReports > 0 ? 'color: darkred;' : '' %>">
              <%= stats.pendingReports %>
            </span>
            <span class="stat-label">Reports</span>
          </div>
        </div>
      </div>

      <div class="settings-card" style="margin-bottom: 1rem; max-width: 100% !important;">
        <h2 class="settings-heading">Reported Spots</h2>
        <% if (reportedSpots.length === 0) { %>
          <p class="section-hint" style="margin-top: 0.75rem;">No reported spots — all clear.</p>
        <% } else { %>
          <div style="margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.75rem;">
            <% reportedSpots.forEach(spot => { %>
              <div class="admin-card admin-report-row" id="report-row-<%= spot.spot_id %>" style="border: 1px solid #f0f2f8; border-radius: 8px; padding: 1rem; background: <%= spot.active ? '#ffffff' : '#fef2f2' %>;">
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f0f0f0; padding-bottom: 12px; margin-bottom: 12px;">
                    <div style="display: flex; align-items: center; gap: 8px; font-size: 0.9rem;">
                        <strong>@<%= spot.username %></strong>
                        <span style="color: #d1d5db;">&bull;</span>
                        <span style="color: #6b7280;"><%= new Date(spot.spot_timestamp).toLocaleDateString('en-GB') %></span>
                        <span data-status style="padding: 2px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; color: <%= spot.active ? '#374151' : 'darkred' %>; background-color: <%= spot.active ? '#f3f4f6' : '#fbcfe8' %>;">
                          <%= spot.active ? 'Visible' : 'Hidden' %>
                        </span>
                    </div>
                    <button class="js-toggle-spot" data-spot-id="<%= spot.spot_id %>" data-active="<%= spot.active %>" style="border: 1px solid #ef4444; color: #ef4444; background: transparent; padding: 6px 14px; border-radius: 6px; font-weight: 500; cursor: pointer;">
                      <%= spot.active ? 'Hide spot' : 'Restore spot' %>
                    </button>
                </div>
                <div style="margin-bottom: 12px; font-weight: 600;"><%= spot.spot_title %></div>
                <div id="reports-list-<%= spot.spot_id %>" style="display: flex; flex-direction: column; gap: 10px;">
                    <% spot.reports.forEach(function(report) { %>
                        <div id="report-<%= report.report_id %>" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 6px; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center;">
                            <p style="margin: 0; font-style: italic; color: #111827;">"<%= report.reason %>"</p>
                            <button class="js-dismiss-report" data-report-id="<%= report.report_id %>" data-spot-id="<%= spot.spot_id %>" style="background: none; border: none; color: #6b7280; font-weight: 500; cursor: pointer;">Dismiss</button>
                        </div>
                    <% }); %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>
  </main>

  <%- include('partials/bottomnav', { activePage: 'admin' }) %>
</div>

<script>
  // (Paste original JS logic from previous block here...)
</script>
</body>
</html>
