<%- include('partials/header') %>

<div class="app-page">
  <%- include('partials/topbar', { showSettings: true }) %>

  <main class="app-content">

    <div class="profile-header">
      <div class="profile-avatar">
        <%= profile?.first_name?.[0]?.toUpperCase() || '?' %><%= profile?.last_name?.[0]?.toUpperCase() || '' %>
      </div>
      <div class="profile-info">
        <p class="profile-name"><%= profile?.first_name || '' %> <%= profile?.last_name || '' %></p>
        <p class="profile-username">@<%= profile?.username || '' %></p>
        <div class="profile-stats">
          <div class="stat">
            <span class="stat-value"><%= spots.length %></span>
            <span class="stat-label">Spots</span>
          </div>
          <div class="stat">
            <span class="stat-value"><%= collection.length %></span>
            <span class="stat-label">Units</span>
          </div>
        </div>
      </div>
    </div>

    <div class="tabs">
      <button class="tab active" data-tab="spots">Spots</button>
      <button class="tab" data-tab="units">Rolling Stock</button>
    </div>

    <div class="tab-content" id="tab-spots">
      <% if (spots.length === 0) { %>
        <div class="empty-state">
          <p>No spots yet.</p>
          <p class="empty-hint">Hit the + button to log your first spot.</p>
        </div>
      <% } else { %>
        <div class="spots-list">
          <% spots.forEach(spot => { %>
            <a href="/spots/<%= spot.spot_id %>" class="spot-item">
                <div class="spot-item-photo<% if (spot.image_thumb_path || spot.image_path) { %> img-loading<% } %>">
                  <% if (spot.image_thumb_path || spot.image_path) { %>
                    <img
                      src="<%= process.env.R2_PUBLIC_URL %>/<%= spot.image_thumb_path || spot.image_path %>"
                      loading="lazy"
                      alt="Spot photo"
                      onload="this.parentElement.classList.remove('img-loading')"
                      onerror="this.parentElement.classList.remove('img-loading')"
                    />
                  <% } else { %>
                    <div class="spot-item-no-photo"><span>No photo</span></div>
                  <% } %>
                </div>
              <div class="spot-item-info">
                <p class="spot-item-title"><%= spot.spot_title %></p>
                <% if (spot.units.length > 0) { %>
                  <p class="spot-item-units"><%= spot.units.map(u => u.unit_number).join(', ') %></p>
                <% } %>
                <p class="spot-item-time"><%= new Date(spot.spot_timestamp).toLocaleString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="tab-content hidden" id="tab-units">
      <% if (classCollection.length === 0) { %>
        <div class="empty-state">
          <p>No units in your collection yet.</p>
          <p class="empty-hint">Units appear here when you log a spot.</p>
        </div>
      <% } else { %>
        <div class="class-grid">
          <% classCollection.forEach((cls, i) => { %>
            <button type="button" class="class-card" data-class-index="<%= i %>" data-class-num="<%= cls.classNum || '' %>">
              <span class="class-card-progress"><%= cls.spotted %><% if (cls.total != null) { %>/<%= cls.total %><% } %></span>
              <div class="class-card-img img-loading"></div>
              <span class="class-card-name"><%= cls.classNum || 'Other' %></span>
            </button>
          <% }) %>
        </div>
      <% } %>
    </div>

  </main>

  <div class="class-sheet" id="class-sheet">
    <div class="class-sheet-handle" id="class-sheet-handle"></div>
    <div class="class-sheet-content" id="class-sheet-content"></div>
  </div>
  <div class="class-sheet-backdrop" id="class-sheet-backdrop"></div>

  <%- include('partials/bottomnav', { activePage }) %>
</div>

<script>
  // Force a fresh reload if the user navigates back to this page via the browser's back button (bfcache)
  window.addEventListener("pageshow", (event) => {
    if (event.persisted) {
      window.location.reload();
    }
  });

  // Tabs — persisted via location.hash so tapping a unit and coming
  // back lands you on the Units tab, not reset to Spots.
  const activateTab = (name) => {
    const tab = document.querySelector(`.tab[data-tab="${name}"]`)
    const panel = document.getElementById(`tab-${name}`)
    if (!tab || !panel) return
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'))
    document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'))
    tab.classList.add('active')
    panel.classList.remove('hidden')
  }

  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      activateTab(tab.dataset.tab)
      history.replaceState(null, '', tab.dataset.tab === 'units' ? '#units' : '#spots')
    })
  })

  if (location.hash === '#units') activateTab('units')
</script>

<script>
  window.SPOTTER_COLLECTION = <%- collectionJson %>;
</script>
<script src="/js/collection.js?v=11"></script>

</body>
</html>
