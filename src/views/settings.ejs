<%- include('partials/header') %>
<script src="/js/toast.js"></script>

<div class="app-page">
  <%- include('partials/topbar', { showBack: true }) %>

  <!-- Force main content wrapper to expand -->
  <main class="app-content" style="max-width: 1200px !important; width: 100%; margin: 0 auto; padding: 0;">
    <!-- Force settings page container to 100% of the 1200px main -->
    <div class="settings-page" style="max-width: 100% !important; width: 100%;">

      <!-- ===== ADMIN ACCESS (VISIBLE TO ADMINS ONLY) ===== -->
      <% if (locals.authUser && locals.authUser.id === process.env.ADMIN_USER_ID) { %>
        <div class="settings-card" style="margin-bottom: 1.5rem; max-width: 100% !important;">
          <h2 class="settings-heading" style="text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; margin-bottom: 0.5rem; color: #64748b; font-weight: 600;">Administration</h2>
          <p class="section-hint" style="margin-bottom: 1rem;">Access the moderation queue and platform statistics.</p>
          <a href="/admin" class="btn" style="display: flex; justify-content: center; align-items: center; width: 100%; padding: 10px; background-color: #ffffff; border: 1px solid #cbd5e1; border-radius: 6px; text-decoration: none; color: #0f172a; font-weight: 500; font-size: 0.95rem; transition: all 0.2s ease;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Open Admin Dashboard
          </a>
        </div>
      <% } %>

      <!-- ===== PROFILE SETTINGS ===== -->
      <div class="settings-card" style="margin-bottom: 1.5rem; max-width: 100% !important;">
        <h2 class="settings-heading" style="text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; margin-bottom: 1rem; color: #64748b; font-weight: 600;">Profile</h2>

        <form id="profile-form" action="/profile" method="POST">
          <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
            <div class="form-group" style="flex: 1; margin-bottom: 0;">
              <label for="first_name" class="form-label">First name</label>
              <input type="text" id="first_name" name="first_name" class="form-control" value="<%= locals.currentUser?.first_name || '' %>">
            </div>
            <div class="form-group" style="flex: 1; margin-bottom: 0;">
              <label for="last_name" class="form-label">Last name</label>
              <input type="text" id="last_name" name="last_name" class="form-control" value="<%= locals.currentUser?.last_name || '' %>">
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="username" class="form-label">Username</label>
            <input type="text" id="username" name="username" class="form-control" value="<%= locals.currentUser?.username || '' %>">
          </div>

          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" class="form-control" value="<%= locals.authUser?.email || '' %>" disabled readonly>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; background-color: midnightblue; color: white;">Save changes</button>
        </form>
      </div>

      <!-- ===== DANGER ZONE ===== -->
      <div class="settings-card" style="max-width: 100% !important;">
        <h2 class="settings-heading" style="text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; margin-bottom: 0.5rem; color: #64748b; font-weight: 600;">Danger Zone</h2>
        <p class="section-hint" style="margin-bottom: 1rem;">Permanently delete your account, all of your spots, and all of your photos. This cannot be undone.</p>

        <form id="delete-account-form" action="/settings/delete" method="POST">
          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="delete_confirm" class="form-label">Type DELETE to confirm</label>
            <input type="text" id="delete_confirm" name="delete_confirm" class="form-control" autocomplete="off">
          </div>

          <button type="submit" class="btn btn-outline-danger js-delete-btn" style="width: 100%; border: 1px solid #fecaca; color: #b91c1c; background: #fff;" disabled>
            Delete my account
          </button>
        </form>
      </div>

    </div>
  </main>

  <%- include('partials/bottomnav', { activePage: 'settings' }) %>
</div>

<script>
  // Logic to only enable the delete button if "DELETE" is exactly typed
  const deleteInput = document.getElementById('delete_confirm');
  const deleteBtn = document.querySelector('.js-delete-btn');

  if (deleteInput && deleteBtn) {
    deleteInput.addEventListener('input', (e) => {
      if (e.target.value === 'DELETE') {
        deleteBtn.disabled = false;
        deleteBtn.style.borderColor = '#ef4444';
        deleteBtn.style.backgroundColor = '#fef2f2';
      } else {
        deleteBtn.disabled = true;
        deleteBtn.style.borderColor = '#fecaca';
        deleteBtn.style.backgroundColor = '#fff';
      }
    });
  }
</script>

</body>
</html>
