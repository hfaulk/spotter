<%- include('partials/header') %>
<script src="/js/toast.js"></script>

<div class="app-page">
  <%- include('partials/topbar', { showBack: true }) %>

  <main class="app-content">
    <div class="settings-page">

      <% if (typeof error !== 'undefined' && error) { %>
        <p class="form-error"><%= error %></p>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <p class="form-success"><%= success %></p>
      <% } %>

      <div class="settings-card">
        <h2 class="settings-heading">Profile</h2>
        <form action="/settings/profile" method="POST" class="settings-form">
          <div class="field-row">
            <div class="field">
              <label for="first_name">First name</label>
              <input type="text" id="first_name" name="first_name"
                value="<%= profile?.first_name || '' %>" required />
            </div>
            <div class="field">
              <label for="last_name">Last name</label>
              <input type="text" id="last_name" name="last_name"
                value="<%= profile?.last_name || '' %>" required />
            </div>
          </div>
          <div class="field">
            <label for="username">Username</label>
            <input type="text" id="username" name="username"
              value="<%= profile?.username || '' %>" required />
          </div>
          <div class="field">
            <label>Email</label>
            <input type="text" value="<%= profile?.user_email || '' %>" disabled />
          </div>
          <button type="submit" class="btn-primary">Save changes</button>
        </form>
      </div>

      <div class="settings-card settings-card-danger">
        <h2 class="settings-heading">Account</h2>
        <a href="/signout" class="btn-danger settings-signout">Sign out</a>
      </div>

      <div class="settings-card settings-card-danger">
        <h2 class="settings-heading">Danger zone</h2>
        <p class="section-hint" style="margin-bottom: 0.85rem;">
          Permanently delete your account, all of your spots, and all of your photos. This cannot be undone.
        </p>
        <form action="/settings/delete-account" method="POST" id="delete-account-form">
          <div class="field" style="margin-bottom: 0.85rem;">
            <label for="delete_confirm">Type DELETE to confirm</label>
            <input type="text" id="delete_confirm" autocomplete="off" autocapitalize="characters" />
          </div>
          <button type="submit" class="btn-danger">Delete my account</button>
        </form>
      </div>

      <p class="auth-link" style="margin-top: 0.5rem;"><a href="/privacy">Privacy policy</a> · <a href="/tos">Terms of service</a></p>

    </div>
  </main>

  <%- include('partials/bottomnav', { activePage }) %>
</div>

<script>
  // Convert server-side messages to toasts
  document.addEventListener('DOMContentLoaded', function() {
    const errorEl = document.querySelector('.form-error');
    if (errorEl) {
      toast.error(errorEl.textContent);
      errorEl.remove();
    }

    const successEl = document.querySelector('.form-success');
    if (successEl) {
      toast.success(successEl.textContent);
      successEl.remove();
    }

    // Profile save feedback
    const profileForm = document.querySelector('.settings-form');
    profileForm?.addEventListener('submit', function() {
      toast.info('Saving...');
    });

    // Account deletion: require typed confirmation
    const deleteForm = document.getElementById('delete-account-form');
    deleteForm?.addEventListener('submit', function(e) {
      const typed = document.getElementById('delete_confirm').value.trim();
      if (typed !== 'DELETE') {
        e.preventDefault();
        toast.warning('Type DELETE in the box to confirm account deletion.');
        return;
      }
      toast.info('Deleting your account...');
      const btn = deleteForm.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Deleting...';
    });
  });
</script>

</body>
</html>
