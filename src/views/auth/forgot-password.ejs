<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="brand-dot"></span>
      <h1>Spotter</h1>
    </div>
    <h2>Reset your password</h2>

    <% if (sent) { %>
      <p class="form-success">Check your email — we've sent you a reset link.</p>
    <% } else { %>
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="form-error"><%= error %></p>
      <% } %>
      <form action="/forgot-password" method="POST" class="auth-form">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required />
        </div>
        <button type="submit" class="btn-primary">Send reset link</button>
      </form>
    <% } %>

    <p class="auth-link"><a href="/login">Back to login</a></p>
  </div>
</div>

<script src="/js/toast.js"></script>
<script>
  // Convert any server-side error/success messages to toasts
  const errorEl = document.querySelector('.form-error');
  if (errorEl) {
    const message = errorEl.textContent.trim();
    if (message) toast.error(message);
    errorEl.remove();
  }

  const successEl = document.querySelector('.form-success');
  if (successEl) {
    const message = successEl.textContent.trim();
    if (message) toast.success(message);
    successEl.remove();
  }
</script>

</body>
</html>
