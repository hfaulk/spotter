<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="brand-dot"></span>
      <h1>Spotter</h1>
    </div>
    <h2>Set a new password</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="form-error"><%= error %></p>
    <% } %>

    <form action="/auth/reset-password" method="POST" class="auth-form" id="reset-form">
      <input type="hidden" name="access_token" id="access_token_input" />
      <div class="field">
        <label for="password">New password</label>
        <input type="password" id="password" name="password"
          placeholder="••••••••" minlength="8" required />
      </div>
      <div class="field">
        <label for="confirm_password">Confirm password</label>
        <input type="password" id="confirm_password" name="confirm_password"
          placeholder="••••••••" minlength="8" required />
      </div>
      <button type="submit" class="btn-primary">Set password</button>
    </form>

    <p class="auth-link"><a href="/login">Back to login</a></p>
  </div>
</div>

<script>
  // Extract access token from URL hash and inject into form
  const hash = window.location.hash.substring(1)
  const params = new URLSearchParams(hash)
  const access_token = params.get('access_token')
  const type = params.get('type')

  if (!access_token || type !== 'recovery') {
    window.location.href = '/login'
  } else {
    document.getElementById('access_token_input').value = access_token
  }

  // Client-side password match validation
  document.getElementById('reset-form').addEventListener('submit', (e) => {
    const password = document.getElementById('password').value
    const confirm = document.getElementById('confirm_password').value
    if (password !== confirm) {
      e.preventDefault()
      alert('Passwords do not match')
    }
  })
</script>

</body>
</html>
