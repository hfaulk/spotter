<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="brand-dot"></span>
      <h1>Lineside</h1>
    </div>
    <h2>Create account</h2>

    <% if (typeof success !== 'undefined' && success) { %>
      <p class="form-success"><%= success %></p>
      <p class="auth-link">Once confirmed, <a href="/login">log in here</a></p>
    <% } else { %>

      <% if (typeof error !== 'undefined' && error) { %>
        <p class="form-error"><%= error %></p>
      <% } %>

      <form action="/register" method="POST" class="auth-form">
        <div class="field-row">
          <div class="field">
            <label for="first_name">First name</label>
            <input type="text" id="first_name" name="first_name"
              value="<%= typeof fields !== 'undefined' ? fields.first_name : '' %>"
              placeholder="John" required />
          </div>
          <div class="field">
            <label for="last_name">Last name</label>
            <input type="text" id="last_name" name="last_name"
              value="<%= typeof fields !== 'undefined' ? fields.last_name : '' %>"
              placeholder="Smith" required />
          </div>
        </div>
        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" name="username"
            value="<%= typeof fields !== 'undefined' ? fields.username : '' %>"
            placeholder="jsmith" required />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email"
            value="<%= typeof fields !== 'undefined' ? fields.email : '' %>"
            placeholder="you@example.com" required autocomplete="username" />
        </div>

        <div class="field password-field">
          <label for="password">Password</label>
          <div class="password-input-wrap">
            <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="new-password" />
            <button type="button" class="password-toggle" aria-label="Show password">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          <ul class="password-reqs" id="password-reqs">
            <li data-req="length">At least 8 characters</li>
            <li data-req="upper">At least one uppercase letter</li>
            <li data-req="number">At least one number</li>
          </ul>
          <div class="strength-bar-wrap">
            <div class="strength-bar" id="strength-bar"></div>
          </div>
        </div>

        <button type="submit" class="btn-primary">Create account</button>
      </form>

      <div class="divider"><span>or</span></div>

      <a href="/auth/google" class="btn-google">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      </a>

      <p class="auth-link">Already have an account? <a href="/login">Log in</a></p>

    <% } %>
  </div>
</div>

<script src="/js/toast.js"></script>
<script>
  const errorEl = document.querySelector('.form-error');
  if (errorEl) {
    const message = errorEl.textContent.trim();
    if (message) toast.error(message);
    errorEl.remove();
  }

  const successEl = document.querySelector('.form-success');
  if (successEl) {
    const message = successEl.textContent.trim();
    if (message) toast.success(message);
    successEl.remove();
  }

  // Password UX Logic
  const passwordInput = document.getElementById('password');
  const toggleBtn = document.querySelector('.password-toggle');
  const bar = document.getElementById('strength-bar');

  if (toggleBtn && passwordInput) {
    toggleBtn.addEventListener('click', () => {
      const isText = passwordInput.type === 'text';
      passwordInput.type = isText ? 'password' : 'text';
      toggleBtn.setAttribute('aria-label', isText ? 'Show password' : 'Hide password');
      toggleBtn.innerHTML = isText
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-off-icon"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
    });
  }

  const reqs = {
    length: v => v.length >= 8,
    upper:  v => /[A-Z]/.test(v),
    number: v => /[0-9]/.test(v),
  };

  function scorePassword(v) {
    let s = 0;
    if (v.length >= 8)  s++;
    if (/[A-Z]/.test(v)) s++;
    if (/[0-9]/.test(v)) s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    if (v.length >= 14) s++;
    return s;
  }

  if (passwordInput) {
    passwordInput.addEventListener('input', () => {
      const v = passwordInput.value;
      document.querySelectorAll('[data-req]').forEach(li => {
        li.classList.toggle('met', reqs[li.dataset.req](v));
      });
      if (bar) bar.dataset.score = scorePassword(v);
    });
  }
</script>

</body>
</html>
