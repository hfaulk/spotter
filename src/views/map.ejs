<%- include('partials/header') %>
<link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet" />

<div class="app-page map-app-page <%= locals.authUser ? '' : 'guest-map' %>">

  <header class="topbar topbar-map">
    <span class="topbar-logo">
      <svg width="7" height="7" viewBox="0 0 7 7">
        <circle cx="3.5" cy="3.5" r="3.5" fill="white"/>
      </svg>
      Spotter
    </span>
  </header>

  <main class="app-content app-content-map">
      <div id="main-map"></div>

      <div class="map-controls">
        <button id="map-toggle-btn" class="map-control-btn" aria-label="Toggle Satellite View" title="Map Layers">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
            <polyline points="2 12 12 17 22 12"></polyline>
            <polyline points="2 17 12 22 22 17"></polyline>
          </svg>
        </button>

        <button id="near-me-btn" class="map-control-btn" aria-label="Near me" title="Near me">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
          </svg>
        </button>
      </div>
    </main>

  <div class="map-sheet" id="map-sheet">
    <div class="map-sheet-handle" id="map-sheet-handle"></div>
    <div class="map-sheet-content" id="map-sheet-content"></div>
  </div>

  <div class="map-sheet-backdrop" id="map-sheet-backdrop"></div>

  <% if (locals.authUser) { %>
    <%- include('partials/bottomnav', { activePage: 'map' }) %>
  <% } else { %>
    <div class="map-guest-bar">
      <p>Discover spotting locations near you</p>
      <div class="map-guest-actions">
        <a href="/register" class="btn-primary" style="width:auto; padding:0.5rem 1.25rem; margin:0; font-size:0.875rem;">Sign up free</a>
        <a href="/login" class="btn-secondary" style="font-size:0.875rem;">Log in</a>
      </div>
    </div>
  <% } %>

</div>

<script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
<script src="/js/toast.js"></script>
<script>
  window.SPOTTER_CONFIG = { isLoggedIn: <%= locals.authUser ? 'true' : 'false' %> }
</script>
<script src="/js/map.js?v=5"></script>

</body>
</html>
