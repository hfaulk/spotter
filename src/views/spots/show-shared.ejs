<%- include('../partials/header') %>
<link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet" />

<div class="show-page">

    <header class="topbar">
      <div class="topbar-left"></div>
      <span class="topbar-logo">Spotter</span>
      <div class="topbar-right"></div>
    </header>

  <% if (imageUrl) { %>
    <div class="spot-image-full">
      <img src="<%= imageUrl %>" alt="<%= spot.spot_title %>" />
    </div>
  <% } %>

  <div class="spot-content">

    <div class="spot-title-block">
      <h1 class="spot-title"><%= spot.spot_title %></h1>
      <% if (spot.spot_description) { %>
        <p class="spot-description"><%= spot.spot_description %></p>
      <% } %>
      <p class="spot-timestamp"><%= new Date(spot.spot_timestamp).toLocaleString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
    </div>

    <% if (units.length > 0) { %>
      <div class="spot-card">
        <h2>Units</h2>
        <div class="units-list">
          <% units.forEach(unit => { %>
            <div class="unit-chip">
              <span class="unit-number"><%= unit.unit_number %></span>
              <% if (unit.unit_class) { %><span class="unit-meta"><%= unit.unit_class %></span><% } %>
              <% if (unit.unit_operator) { %><span class="unit-meta"><%= unit.unit_operator %></span><% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (spot.spot_latitude && spot.spot_longitude) { %>
      <div class="spot-card">
        <h2>Location</h2>
        <div id="spot-map"
          data-lat="<%= spot.spot_latitude %>"
          data-lon="<%= spot.spot_longitude %>">
        </div>
      </div>
    <% } %>

    <div class="spot-card shared-cta">
      <p>Logged with <strong>Spotter</strong></p>
      <a href="/register" class="btn-primary">Start spotting</a>
    </div>

  </div>
</div>

<script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
<script>
  const mapEl = document.getElementById('spot-map')
  if (mapEl) {
    const lat = parseFloat(mapEl.dataset.lat)
    const lon = parseFloat(mapEl.dataset.lon)
    const map = new maplibregl.Map({
      container: 'spot-map',
      style: 'https://tiles.openfreemap.org/styles/liberty',
      center: [lon, lat],
      zoom: 14
    })
    map.on('load', () => {
      new maplibregl.Marker().setLngLat([lon, lat]).addTo(map)
    })
  }
</script>

</body>
</html>
