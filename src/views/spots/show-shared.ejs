<%- include('../partials/header') %>
<link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet" />

<div class="show-page layout-spot shared-layout">

  <header class="topbar">
    <div class="topbar-left"></div>
    <span class="topbar-logo">Spotter</span>
    <div class="topbar-right"></div>
  </header>

  <div class="spot-image-full<% if (imageUrl) { %> img-loading-dark<% } %>">
    <% if (imageUrl) { %>
      <div class="spot-image-bg" style="background-image:url('<%= imageUrl %>')"></div>
      <img
        src="<%= imageUrl %>"
        alt="<%= spot.spot_title %>"
        onload="this.closest('.spot-image-full').classList.remove('img-loading-dark')"
        onerror="this.closest('.spot-image-full').classList.remove('img-loading-dark')"
      />
    <% } else { %>
      <div class="spot-image-placeholder"></div>
    <% } %>
  </div>

  <div class="show-right">
      <div class="spot-title-block">
            <h1 class="spot-title"><%= spot.spot_title %></h1>
            <% if (spot.spot_description) { %>
              <p class="spot-description"><%= spot.spot_description %></p>
            <% } %>
            <p class="spot-timestamp"><%= new Date(spot.spot_timestamp).toLocaleString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>

            <% if (spot.user) { %>
              <a class="shared-author">
                <div class="shared-author-avatar<% if (spot.user.avatar_path) { %> img-loading<% } %>">
                <% if (spot.user.avatar_path) { %>
                    <img src="<%= process.env.R2_PUBLIC_URL %>/<%= spot.user.avatar_path %>"
                         alt="<%= spot.user.first_name %>"
                         onload="this.parentElement.classList.remove('img-loading')"
                         onerror="this.parentElement.classList.remove('img-loading')"
                    />
                <% } else { %>
                    <%= (spot.user.first_name ? spot.user.first_name.charAt(0).toUpperCase() : '') + (spot.user.last_name ? spot.user.last_name.charAt(0).toUpperCase() : '') || '?' %>
                <% } %>
                </div>
                <div class="shared-author-info">
                  <span class="shared-author-name">Spotted by <%= spot.user.first_name %> <%= spot.user.last_name %></span>
                  <span class="shared-author-username">@<%= spot.user.username %></span>
               </div>
              </a>
            <% } %>

          </div>

    <div class="spot-content">

      <% if (units.length > 0) { %>
        <div class="spot-card">
          <h2>Units</h2>
          <div class="units-list">
            <% units.forEach(unit => { %>
              <div class="unit-chip">
                <span class="unit-number"><%= unit.unit_number %></span>
                <% if (unit.unit_class) { %><span class="unit-meta"><%= unit.unit_class %></span><% } %>
                <% if (unit.unit_operator) { %><span class="unit-meta"><%= unit.unit_operator %></span><% } %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (spot.image_camera || spot.image_shutter_speed || spot.image_iso || spot.image_aperture || spot.image_focal_length) { %>
        <div class="spot-card">
          <h2>Camera</h2>
          <div class="exif-grid">
            <% if (spot.image_camera) { %>
              <div class="exif-item"><span class="exif-label">Camera</span><span class="exif-value"><%= spot.image_camera %></span></div>
            <% } %>
            <% if (spot.image_shutter_speed) { %>
              <div class="exif-item"><span class="exif-label">Shutter</span><span class="exif-value"><%= spot.image_shutter_speed %></span></div>
            <% } %>
            <% if (spot.image_aperture) { %>
              <div class="exif-item"><span class="exif-label">Aperture</span><span class="exif-value"><%= spot.image_aperture %></span></div>
            <% } %>
            <% if (spot.image_iso) { %>
              <div class="exif-item"><span class="exif-label">ISO</span><span class="exif-value"><%= spot.image_iso %></span></div>
            <% } %>
            <% if (spot.image_focal_length) { %>
              <div class="exif-item"><span class="exif-label">Focal length</span><span class="exif-value"><%= spot.image_focal_length %></span></div>
            <% } %>
          </div>
        </div>
      <% } %>

      <% if (spot.spot_latitude && spot.spot_longitude) { %>
        <div class="spot-card card-location">
          <h2>Location</h2>
          <div id="spot-map"
            data-lat="<%= spot.spot_latitude %>"
            data-lon="<%= spot.spot_longitude %>">
          </div>
        </div>
      <% } %>

      <div class="spot-card shared-cta">
        <p>Logged with <strong>Spotter</strong></p>
        <a href="/register" class="btn-primary">Start spotting</a>
      </div>

      <!-- Report Feature -->
        <div style="text-align: center; margin-top: 32px; margin-bottom: 32px; padding-top: 16px; border-top: 1px solid #e2e8f0;">
            <button type="button"
                class="js-report-btn"
                data-reference="Shared Spot Token: <%= spot.spot_share_token %>"
                data-type="shared"
                style="background:none; border:none; padding:0; font-size: 0.85rem; color: #94a3b8; text-decoration: underline; cursor: pointer; transition: color 0.2s; font-family: inherit;"
                onmouseover="this.style.color='#ef4444'"
                onmouseout="this.style.color='#94a3b8'">
            Report inappropriate content
            </button>
        </div>

    </div>
  </div>
</div>

<script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
<script>
  const mapEl = document.getElementById('spot-map')
  if (mapEl) {
    const lat = parseFloat(mapEl.dataset.lat)
    const lon = parseFloat(mapEl.dataset.lon)
    const map = new maplibregl.Map({
      container: 'spot-map',
      style: 'https://tiles.openfreemap.org/styles/liberty',
      center: [lon, lat],
      zoom: 14
    })
    map.on('load', () => {
      new maplibregl.Marker().setLngLat([lon, lat]).addTo(map)
    })
  }
</script>

</body>
</html>
