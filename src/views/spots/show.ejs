<%- include('../partials/header') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="show-page">

  <!-- HERO -->
  <div class="spot-hero">
    <% if (imageUrl) { %>
      <img src="<%= imageUrl %>" alt="<%= spot.spot_title %>" class="spot-hero-img" />
    <% } else { %>
      <div class="spot-hero-placeholder"></div>
    <% } %>
    <div class="spot-hero-overlay"></div>
    <a href="/dashboard" class="spot-hero-back">← Back</a>
    <h1 class="spot-hero-title"><%= spot.spot_title %></h1>
  </div>

  <!-- CONTENT -->
  <div class="spot-content">

    <div class="spot-card">
      <% if (spot.spot_description) { %>
        <p class="spot-description"><%= spot.spot_description %></p>
      <% } %>
      <p class="spot-timestamp"><%= new Date(spot.spot_timestamp).toLocaleString('en-GB') %></p>
    </div>

    <% if (units.length > 0) { %>
      <div class="spot-card">
        <h2>Units</h2>
        <div class="units-list">
          <% units.forEach(unit => { %>
            <div class="unit-chip">
              <span class="unit-number"><%= unit.unit_number %></span>
              <% if (unit.unit_class) { %>
                <span class="unit-meta"><%= unit.unit_class %></span>
              <% } %>
              <% if (unit.unit_operator) { %>
                <span class="unit-meta"><%= unit.unit_operator %></span>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (spot.image_camera || spot.image_shutter_speed || spot.image_iso || spot.image_aperture || spot.image_focal_length) { %>
      <div class="spot-card">
        <h2>Camera</h2>
        <div class="exif-grid">
          <% if (spot.image_camera) { %>
            <div class="exif-item">
              <span class="exif-label">Camera</span>
              <span class="exif-value"><%= spot.image_camera %></span>
            </div>
          <% } %>
          <% if (spot.image_shutter_speed) { %>
            <div class="exif-item">
              <span class="exif-label">Shutter</span>
              <span class="exif-value"><%= spot.image_shutter_speed %></span>
            </div>
          <% } %>
          <% if (spot.image_aperture) { %>
            <div class="exif-item">
              <span class="exif-label">Aperture</span>
              <span class="exif-value"><%= spot.image_aperture %></span>
            </div>
          <% } %>
          <% if (spot.image_iso) { %>
            <div class="exif-item">
              <span class="exif-label">ISO</span>
              <span class="exif-value"><%= spot.image_iso %></span>
            </div>
          <% } %>
          <% if (spot.image_focal_length) { %>
            <div class="exif-item">
              <span class="exif-label">Focal length</span>
              <span class="exif-value"><%= spot.image_focal_length %></span>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <% if (spot.spot_latitude && spot.spot_longitude) { %>
      <div class="spot-card">
        <h2>Location</h2>
        <div id="spot-map"
          data-lat="<%= spot.spot_latitude %>"
          data-lon="<%= spot.spot_longitude %>">
        </div>
      </div>
    <% } %>

    <div class="spot-card">
      <h2>Share</h2>
      <p class="section-hint">Share this spot with anyone — they won't need an account to view it.</p>
      <div class="share-row">
        <span class="share-url" id="share-url"><%= process.env.BASE_URL ?? '' %>/s/<%= spot.spot_share_token %></span>
        <button type="button" id="copy-share" class="btn-secondary">Copy</button>
      </div>
    </div>

  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const mapEl = document.getElementById('spot-map')
  if (mapEl) {
    const lat = parseFloat(mapEl.dataset.lat)
    const lon = parseFloat(mapEl.dataset.lon)
    const map = L.map('spot-map', { zoomControl: true, dragging: false, scrollWheelZoom: false })
      .setView([lat, lon], 14)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map)
    L.marker([lat, lon]).addTo(map)
    setTimeout(() => map.invalidateSize(), 200)
  }

  const copyBtn = document.getElementById('copy-share')
  const shareUrl = document.getElementById('share-url')

  const fallbackCopy = (text) => {
    const ta = document.createElement('textarea')
    ta.value = text
    document.body.appendChild(ta)
    ta.select()
    document.execCommand('copy')
    document.body.removeChild(ta)
  }

  copyBtn?.addEventListener('click', () => {
    const url = shareUrl.textContent.trim()
    const onSuccess = () => {
      copyBtn.textContent = 'Copied!'
      setTimeout(() => copyBtn.textContent = 'Copy', 2000)
    }
    if (navigator.clipboard) {
      navigator.clipboard.writeText(url).then(onSuccess).catch(() => { fallbackCopy(url); onSuccess() })
    } else {
      fallbackCopy(url)
      onSuccess()
    }
  })
</script>

</body>
</html>
