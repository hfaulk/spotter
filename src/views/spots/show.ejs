<%- include('../partials/header') %>
<link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet" />

<div class="show-page layout-spot">

  <div class="spot-image-full<% if (imageUrl) { %> img-loading-dark<% } %>">
    <% if (imageUrl) { %>
      <div class="spot-image-bg" style="background-image:url('<%= imageUrl %>')"></div>
      <img
        src="<%= imageUrl %>"
        alt="<%= spot.spot_title %>"
        onload="this.closest('.spot-image-full').classList.remove('img-loading-dark')"
        onerror="this.closest('.spot-image-full').classList.remove('img-loading-dark')"
      />
    <% } else { %>
      <div class="spot-image-placeholder"></div>
    <% } %>

    <button class="spot-back-btn js-back-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Back
    </button>

    <div class="spot-menu">
      <button class="spot-menu-trigger" id="spot-menu-trigger" aria-label="More options">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
           <circle cx="12" cy="5" r="1" fill="currentColor"/><circle cx="12" cy="12" r="1" fill="currentColor"/><circle cx="12" cy="19" r="1" fill="currentColor"/>
        </svg>
      </button>
      <div class="spot-menu-dropdown" id="spot-menu-dropdown">
          <button class="spot-menu-item spot-menu-item-danger" id="delete-btn" data-spot-id="<%= spot.spot_id %>">Delete spot</button>
      </div>
    </div>
  </div>

  <div class="show-right">
    <div class="spot-title-block">
      <h1 class="spot-title"><%= spot.spot_title %></h1>
      <% if (spot.spot_description) { %>
         <p class="spot-description"><%= spot.spot_description %></p>
      <% } %>
      <p class="spot-timestamp"><%= new Date(spot.spot_timestamp).toLocaleString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
    </div>

    <div class="spot-content">

      <% if (units.length > 0) { %>
        <div class="spot-card">
          <h2>Units</h2>
          <div class="units-list">
            <% units.forEach(unit => { %>
              <a href="/units/<%= unit.unit_id %>" class="unit-chip">
                <span class="unit-number"><%= unit.unit_number %></span>
                <% if (unit.unit_class) { %><span class="unit-meta"><%= unit.unit_class %></span><% } %>
                <% if (unit.unit_operator) { %><span class="unit-meta"><%= unit.unit_operator %></span><% } %>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (spot.image_camera || spot.image_shutter_speed || spot.image_iso || spot.image_aperture || spot.image_focal_length) { %>
        <div class="spot-card">
          <h2>Camera</h2>
          <div class="exif-grid">
            <% if (spot.image_camera) { %>
              <div class="exif-item"><span class="exif-label">Camera</span><span class="exif-value"><%= spot.image_camera %></span></div>
            <% } %>
            <% if (spot.image_shutter_speed) { %>
              <div class="exif-item"><span class="exif-label">Shutter</span><span class="exif-value"><%= spot.image_shutter_speed %></span></div>
            <% } %>
            <% if (spot.image_aperture) { %>
              <div class="exif-item"><span class="exif-label">Aperture</span><span class="exif-value"><%= spot.image_aperture %></span></div>
            <% } %>
            <% if (spot.image_iso) { %>
              <div class="exif-item"><span class="exif-label">ISO</span><span class="exif-value"><%= spot.image_iso %></span></div>
            <% } %>
            <% if (spot.image_focal_length) { %>
              <div class="exif-item"><span class="exif-label">Focal length</span><span class="exif-value"><%= spot.image_focal_length %></span></div>
            <% } %>
          </div>
         </div>
      <% } %>

      <% if (spot.spot_latitude && spot.spot_longitude) { %>
        <div class="spot-card card-location">
          <h2>Location</h2>
          <div id="spot-map" data-lat="<%= spot.spot_latitude %>" data-lon="<%= spot.spot_longitude %>"></div>
        </div>
      <% } %>

      <div class="spot-card card-full">
        <h2>Share</h2>
        <p class="section-hint">Share this spot with anyone — they won't need an account to view it.</p>
        <div class="share-row">
          <span class="share-url" id="share-url" data-token="<%= spot.spot_share_token %>">Generating link...</span>
          <button type="button" id="copy-share" class="btn-secondary">Copy</button>
        </div>
      </div>

      <!-- User Support Link -->
        <div style="margin-top: 24px; margin-bottom: 24px; text-align: center;">
            <button type="button"
                class="js-report-btn"
                data-reference="Spot ID: <%= spot.spot_id %>"
                data-type="private"
                style="background:none; border:none; padding:0; font-size: 0.85rem; color: #94a3b8; text-decoration: none; cursor: pointer; transition: color 0.2s; font-family: inherit;"
                onmouseover="this.style.color='#1e3a8a'"
                onmouseout="this.style.color='#94a3b8'">
            Need help with this spot? Contact Support
            </button>
        </div>

    </div>
  </div>

  <%- include('../partials/bottomnav', { activePage: 'profile' }) %>
</div>

<script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
<script src="/js/toast.js"></script>
<script src="/js/main.js"></script>
<script src="/js/spot-show.js"></script>
</body>
</html>
