{
  "_meta": {
    "version": "1.0.0",
    "description": "UK railway rolling stock class database for Spotter auto-detection",
    "usage": "Keys are the first 2-3 characters of a unit number. Detection tries 3-char key first, then 2-char.",
    "fields": {
      "class": "Human-readable class designation (e.g. 'Class 444')",
      "subtype": "Product/series name (e.g. 'Desiro', 'Electrostar')",
      "type": "Traction category: EMU | DMU | DEMU | Loco (Diesel) | Loco (Electric) | Loco (Electro-Diesel) | Bi-mode | Tram-train",
      "operator": "Primary/most common current operator. 'Various' where multiple equally common.",
      "traction": "Power supply: 25kV AC | 750V DC | diesel | dual (AC+diesel) | dual (DC+diesel)",
      "formation": "Typical unit formation",
      "notes": "Optional context"
    },
    "key_convention": {
      "3-digit": "Used for Classes 100–999 (EMUs, DMUs, modern locos 100+)",
      "2-digit": "Used for Classes 20–99 (classic locos, electro-diesels)"
    }
  },

